{
  "testEnvironment": "node",
  "testMatch": [
    "**/__tests__/**/*.test.js"
  ],
  "collectCoverageFrom": [
    "src/**/*.js",
    "!src/index.js"
  ],
  "coverageThreshold": {
    "global": {
      "branches": 60,
      "functions": 70,
      "lines": 70,
      "statements": 70
    }
  },
  "coverageReporters": ["text", "lcov", "html"],
  "testTimeout": 30000,
  "setupFilesAfterEnv": [],
  "verbose": true
}
