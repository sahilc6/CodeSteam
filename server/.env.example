PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/codesteam
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
CORS_ORIGINS=http://localhost:5173
CLIENT_URL=http://localhost:5173

# Email verification
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
MAIL_FROM=CodeSteam <no-reply@example.com>

# Code execution
SANDBOX_TIMEOUT_MS=10000
CODE_RUNNER_MODE=local
ALLOW_LOCAL_CODE_EXECUTION=true
SANDBOX_RUN_AS_USER=sandbox:sandbox

# Use these only for self-hosted/VPS deployments that support Docker-per-run.
SANDBOX_DOCKER_IMAGE=codesteam-sandbox:latest
SANDBOX_DOCKER_MEMORY=256m
SANDBOX_DOCKER_CPUS=0.5
SANDBOX_DOCKER_PIDS_LIMIT=64
