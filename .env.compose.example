MONGO_USER=admin
MONGO_PASSWORD=replace-with-a-strong-password
DOCKER_GID=0
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
CORS_ORIGINS=http://localhost
CLIENT_URL=http://localhost

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
MAIL_FROM=CodeSteam <no-reply@example.com>

SANDBOX_TIMEOUT_MS=10000
CODE_RUNNER_MODE=docker
ALLOW_LOCAL_CODE_EXECUTION=false
SANDBOX_RUN_AS_USER=
SANDBOX_DOCKER_IMAGE=codesteam-sandbox:latest
SANDBOX_DOCKER_MEMORY=256m
SANDBOX_DOCKER_CPUS=0.5
SANDBOX_DOCKER_PIDS_LIMIT=64
VITE_API_URL=
VITE_WS_URL=
